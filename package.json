{
  "name": "@mohtasham/md-to-docx",
  "version": "2.10.2",
  "description": "Convert Markdown to Microsoft Word (.docx) documents with support for various Markdown features",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "md-to-docx": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js --config jest.config.mjs",
    "test:single": "node --experimental-vm-modules node_modules/jest/bin/jest.js --config jest.config.mjs",
    "prepare": "npm run build",
    "release": "semantic-release"
  },
  "keywords": [
    "markdown",
    "docx",
    "word",
    "converter",
    "typescript"
  ],
  "author": "Mohtasham",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MohtashamMurshid/md-to-docx.git"
  },
  "bugs": {
    "url": "https://github.com/MohtashamMurshid/md-to-docx/issues"
  },
  "homepage": "https://github.com/MohtashamMurshid/md-to-docx#readme",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "files": [
    "dist"
  ],
  "devDependencies": {
    "@semantic-release/changelog": "6.0.3",
    "@semantic-release/git": "10.0.1",
    "@types/file-saver": "^2.0.7",
    "@types/jest": "^29.5.12",
    "@types/mdast": "^4.0.4",
    "@types/node": "^20.11.24",
    "conventional-changelog-conventionalcommits": "9.3.1",
    "jest": "^29.7.0",
    "jszip": "^3.10.1",
    "semantic-release": "25.0.3",
    "ts-jest": "^29.1.2",
    "typescript": "^5.8.2"
  },
  "dependencies": {
    "docx": "^9.5.0",
    "file-saver": "^2.0.5",
    "lowlight": "^3.3.0",
    "mdast-util-find-and-replace": "^3.0.2",
    "remark": "^15.0.1",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.0.0"
  }
}
